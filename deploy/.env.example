# =============================================================================
# quantum-price-inference — environment variables
#
# Copy this file to deploy/.env and adjust values for your deployment.
# The .env file is gitignored — never commit credentials or secrets.
#
# All QPI_* variables map directly to Settings fields in api/config.py.
# Values shown are the defaults; omit any line to accept the default.
# =============================================================================

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
QPI_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
QPI_LOG_JSON=true           # true → structured JSON lines (recommended for prod)

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
QPI_WORKERS=2               # uvicorn worker count (docker-compose only; local dev uses 1)

# ---------------------------------------------------------------------------
# CORS — JSON list of allowed origins
# Default: localhost:8888 (Jupyter) and localhost:3000 (dev frontend)
# Expand for production: QPI_CORS_ORIGINS='["https://myapp.example.com"]'
# ---------------------------------------------------------------------------
# QPI_CORS_ORIGINS=["http://localhost:8888","http://localhost:3000","http://127.0.0.1:8888","http://127.0.0.1:3000"]

# ---------------------------------------------------------------------------
# Rate limiting (slowapi format: "N/period")
# ---------------------------------------------------------------------------
QPI_CLASSICAL_RATE_LIMIT=30/minute
QPI_QUANTUM_RATE_LIMIT=10/minute

# ---------------------------------------------------------------------------
# Quantum estimation timeout
# Raise for large circuits (small epsilon); lower to free threads faster.
# ---------------------------------------------------------------------------
QPI_ESTIMATION_TIMEOUT_SECONDS=30.0

# ---------------------------------------------------------------------------
# In-process LRU cache sizes
# Note: caches are per-worker — for multi-worker deployments use Redis (Wave 5.2).
# ---------------------------------------------------------------------------
QPI_CLASSICAL_CACHE_MAXSIZE=256
QPI_QUANTUM_CACHE_MAXSIZE=128

# ---------------------------------------------------------------------------
# Grafana admin password — change before first deployment
# ---------------------------------------------------------------------------
QPI_GRAFANA_PASSWORD=changeme
