# =============================================================================
# quantum-price-inference — environment variables
#
# Copy this file to deploy/.env and fill in real values.
# The .env file is gitignored — never commit credentials.
# =============================================================================

# API runtime config
QPI_LOG_LEVEL=INFO
QPI_LOG_JSON=true
QPI_WORKERS=2

# Grafana admin password — change before first deployment
QPI_GRAFANA_PASSWORD=changeme
